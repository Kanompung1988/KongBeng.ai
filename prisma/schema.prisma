// Prisma schema for Khongbeng stock analysis platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Admin User ───────────────────────────────────────────────────────────────
model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  stocks    Stock[]

  @@map("admin_users")
}

// ─── Stock ────────────────────────────────────────────────────────────────────
model Stock {
  id     String @id @default(cuid())
  symbol String @unique               // e.g. "CPALL", "NVDA"
  name   String                       // e.g. "CP All Public Company Limited"
  sector String                       // e.g. "Consumer Staples"
  exchange String  @default("SET")    // e.g. "SET", "NASDAQ", "NYSE"
  logoUrl String?                     // clearbit logo URL
  marketIndexes String[] @default([]) // e.g. ["SET50", "SP500", "NASDAQ100"]

  // ── 8 Core Analysis Sections (New) ────────────────────────────────────────
  coreBusiness   String? @db.Text  // JSON: ธุรกิจหลัก + BU pie chart data
  customerBase   String? @db.Text  // JSON: ฐานลูกค้า + stickiness
  revenueModel   String? @db.Text  // JSON: Model รายได้ + quality
  financials     String? @db.Text  // JSON: งบการเงิน 5 ปี + charts
  sevenPowers    String? @db.Text  // JSON: 7 Powers analysis + radar
  storyAndSCurve String? @db.Text  // JSON: Story & S-Curve + hidden gems
  risks          String? @db.Text  // JSON: ความเสี่ยง
  ceoProfile     String? @db.Text  // JSON: CEO Profile & Execution

  // ── Optional Sections ─────────────────────────────────────────────────────
  shareholders   String? @db.Text  // JSON: รายชื่อผู้ถือหุ้น
  recentNews     String? @db.Text  // JSON: ข่าวล่าสุด

  // ── Meta ────────────────────────────────────────────────────────────────────
  isPublished Boolean  @default(false)
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  updatedById String?    @map("updated_by")
  updatedBy   AdminUser? @relation(fields: [updatedById], references: [id])

  // Indexes
  @@index([symbol])
  @@index([sector])
  @@index([exchange])
  @@index([isPublished])
  @@map("stocks")
}

// ─── User (public registered users) ─────────────────────────────────────────
model User {
  id        String   @id            // = Supabase Auth UID
  email     String   @unique
  name      String?
  avatarUrl String?  @map("avatar_url")
  status    String   @default("pending") // "pending" | "approved" | "rejected"
  approvedBy String? @map("approved_by")
  approvedAt DateTime? @map("approved_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  portfolios Portfolio[]
  alerts     Alert[]

  @@map("users")
}

// ─── Portfolio (user stock watchlist / portfolio) ────────────────────────────
model Portfolio {
  id          String          @id @default(cuid())
  userId      String          @map("user_id")
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String          @default("My Portfolio")
  isWatchlist  Boolean         @default(false) @map("is_watchlist")
  items       PortfolioItem[]
  transactions Transaction[]
  snapshots   PortfolioSnapshot[]
  dividends   DividendRecord[]
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@unique([userId, name])
  @@index([userId])
  @@map("portfolios")
}

model PortfolioItem {
  id          String    @id @default(cuid())
  portfolioId String    @map("portfolio_id")
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  stockId     String    @map("stock_id")
  symbol      String
  shares      Float?
  avgCost     Float?    @map("avg_cost")
  notes       String?   @db.Text
  addedAt     DateTime  @default(now()) @map("added_at")

  @@unique([portfolioId, stockId])
  @@index([portfolioId])
  @@index([stockId])
  @@map("portfolio_items")
}

// ─── Chat Sessions (for AI Chatbot) ──────────────────────────────────────────
model ChatSession {
  id        String        @id @default(cuid())
  stockId   String        @map("stock_id")
  sessionId String        @unique @map("session_id") // anonymous browser session
  messages  ChatMessage[]
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String      @map("session_id")
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String      // "user" | "assistant"
  content   String      @db.Text
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([sessionId])
  @@map("chat_messages")
}

// ─── Page Views Analytics ─────────────────────────────────────────────────────
model PageView {
  id        String   @id @default(cuid())
  symbol    String
  path      String
  referrer  String?
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([symbol])
  @@index([createdAt])
  @@map("page_views")
}

// ─── Trend Articles (AI-generated investment news) ──────────────────────────
model TrendArticle {
  id          String   @id @default(cuid())
  title       String
  titleTh     String?  @map("title_th")
  summary     String   @db.Text
  summaryTh   String?  @db.Text @map("summary_th")
  content     String   @db.Text
  contentTh   String?  @db.Text @map("content_th")
  category    String   // "macro", "tech", "commodities", "crypto", "thai-market"
  tags        String[]
  imageUrl    String?  @map("image_url")
  source      String?
  publishedAt DateTime @default(now()) @map("published_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([publishedAt])
  @@index([category])
  @@map("trend_articles")
}

// ─── Transaction (buy/sell/dividend records) ─────────────────────────────────
model Transaction {
  id          String   @id @default(cuid())
  portfolioId String   @map("portfolio_id")
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  stockId     String   @map("stock_id")
  symbol      String
  type        String   // "buy" | "sell" | "dividend"
  shares      Float
  price       Float
  fees        Float    @default(0)
  currency    String   @default("THB")
  date        DateTime @default(now())
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([portfolioId])
  @@index([stockId])
  @@index([date])
  @@map("transactions")
}

// ─── Portfolio Snapshot (daily value for historical chart) ───────────────────
model PortfolioSnapshot {
  id          String   @id @default(cuid())
  portfolioId String   @map("portfolio_id")
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  totalValue  Float    @map("total_value")
  totalCost   Float    @map("total_cost")
  currency    String   @default("THB")
  date        DateTime @default(now())
  breakdown   String?  @db.Text // JSON: {symbol: value}[]

  @@unique([portfolioId, date])
  @@index([portfolioId, date])
  @@map("portfolio_snapshots")
}

// ─── Price Alerts ────────────────────────────────────────────────────────────
model Alert {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol      String
  targetPrice Float     @map("target_price")
  direction   String    // "above" | "below"
  isTriggered Boolean   @default(false) @map("is_triggered")
  triggeredAt DateTime? @map("triggered_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([symbol])
  @@map("alerts")
}

// ─── Dividend Records ────────────────────────────────────────────────────────
model DividendRecord {
  id          String    @id @default(cuid())
  portfolioId String    @map("portfolio_id")
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  stockId     String    @map("stock_id")
  symbol      String
  amount      Float
  perShare    Float?    @map("per_share")
  exDate      DateTime? @map("ex_date")
  payDate     DateTime? @map("pay_date")
  currency    String    @default("THB")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([portfolioId])
  @@index([stockId])
  @@map("dividend_records")
}
