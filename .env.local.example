# KongBeng AI — Environment Variables
# Copy this file to .env.local and fill in your values

# ─── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — used by admin routes (keep secret, server-only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Database (Prisma) ────────────────────────────────────────────────────────
# Use the connection POOLER URL (port 6543) for DATABASE_URL
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Use the direct URL (port 5432) for migrations only
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# ─── Gemini AI (Google) — get key at: https://aistudio.google.com ─────────────
GEMINI_API_KEY=your-gemini-api-key-here
# Optional: override model (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# ─── Typhoon AI (SCB 10X) — get key at: https://opentyphoon.ai ───────────────
TYPHOON_API_KEY=sk-your-typhoon-key-here

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=KongBeng Strategist

# ─── Admin ───────────────────────────────────────────────────────────────────
# Comma-separated list of admin email addresses
ADMIN_EMAILS=admin@example.com,another@example.com

# ─── Cron Job Auth ───────────────────────────────────────────────────────────
# Secret token for /api/trend/generate — set in Vercel Cron config
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-cron-secret-here
